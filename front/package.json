    "cypress:run": "cypress run"
  },
  "private": true,
  "packageManager": "npm@10.9.0",
  "dependencies": {
    "@angular/cdk": "^21.2.6",
    "@angular/common": "^21.2.11",
    "@angular/compiler": "^21.2.11",
    "@angular/core": "^21.2.11",
    "@angular/forms": "^21.2.11",
    "@angular/material": "^21.2.6",
    "@angular/platform-browser": "^21.2.11",
    "@angular/router": "^21.2.11",
    "ngx-build-plus": "^20.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "^21.0.3",
    "@angular/animations": "^21.2.11",
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "^21.2.11",
    "@angular/platform-browser-dynamic": "^21.2.11",
    "@cypress/code-coverage": "^4.0.3",
