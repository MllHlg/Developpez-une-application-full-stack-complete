    "@jsdevtools/coverage-istanbul-loader": "^3.0.5",
    "@types/jest": "^30.0.0",
    "babel-plugin-istanbul": "^8.0.0",
    "cypress": "15.14.2",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-preset-angular": "^16.1.4",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  },
  "nyc": {
    "report-dir": "coverage/cypress"
